---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
}

/* fallback values when a page forgets to set front-matter */
const pageTitle = Astro.props.title ?? "ScrapNet";
const pageDesc =
  Astro.props.description ??
  "ScrapNet is an open, licence-friendly library of printable gadgets, firmware, and prompt packs.";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />

    <!-- Light/Dark support & address-bar tint -->
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="var(--accent)" />

    <!-- Open Graph for link previews (logo.png used until a full OG image exists)-->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content="https://scrapnet.eu/" />
    <meta property="og:image" content="https://scrapnet.eu/logo.png" />
    <meta property="og:type" content="website" />

    <!-- Icons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <!-- Optional: add png / apple-touch icons later if you need them -->
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Fonts – Inter (text) + VT323 (monospace headings) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=VT323&display=swap"
      rel="stylesheet"
    />

    <!-- Privacy / GDPR machine-readable stub -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "ScrapNet",
        "url": "https://scrapnet.eu/"
      }
    </script>
  </head>

  <body class="antialiased bg-[var(--bg)] text-[var(--fg)]">
    <!-- Future: consent banner can mount here -->
    <slot />
  </body>
</html>
